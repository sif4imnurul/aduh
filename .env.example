# API key used by Agent 2 (OpenRouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Base URL used by Agent 3 when sending live requests
TARGET_BASE_URL=http://localhost:8000

# Optional tuning for live requests
REQUEST_TIMEOUT=30
DELAY_BETWEEN_REQUESTS=0.5

# Output folders
REPORT_OUTPUT_DIR=./reports
